Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	Если НЕ ЗначениеЗаполнено(Заказ) Тогда
		Сообщить("Не заполнен заказ.");
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Если Сумма <= 0 Тогда
		Сообщить("Сумма оплаты должна быть больше нуля.");
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ВидОплаты) Тогда
		Сообщить("Не заполнен вид оплаты.");
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Если ВидОплаты = Перечисления.ВидОплаты.ОтЗаказчика И НЕ ЗначениеЗаполнено(КонтрагентЗаказчик) Тогда
		Сообщить("Для вида оплаты ""От заказчика"" заполните заказчика.");
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Если ВидОплаты = Перечисления.ВидОплаты.Поставщику И НЕ ЗначениеЗаполнено(КонтрагентПоставщик) Тогда
		Сообщить("Для вида оплаты ""Поставщику"" заполните поставщика.");
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Если ВидОплаты = Перечисления.ВидОплаты.Перевозчику И НЕ ЗначениеЗаполнено(КонтрагентПеревозчик) Тогда
		Сообщить("Для вида оплаты ""Перевозчику"" заполните перевозчика.");
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(КурсВалюты) ИЛИ КурсВалюты = 0 Тогда
		КурсВалюты = 1;
	КонецЕсли;
	СуммаРуб = Сумма * КурсВалюты;

	Если НЕ ЗначениеЗаполнено(ДатаОплатыФакт) Тогда
		ДатаОплатыФакт = Дата;
	КонецЕсли;

КонецПроцедуры

Процедура ПриПроведении(Отказ, РежимПроведения)
	ЛогикаФинансов.ЗарегистрироватьОплату(ЭтотОбъект);
КонецПроцедуры
