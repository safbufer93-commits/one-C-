	ОбновитьСписки();
КонецПроцедуры

Процедура ОбновитьСписки() Экспорт
	// Серверная заготовка обновления данных рабочего стола.
	// Фактическое отображение выполняется формой обработки.
КонецПроцедуры

Функция ПолучитьМоиЗаказы(ПериодНачало = Неопределено, ПериодКонец = Неопределено) Экспорт

	Если ПериодНачало = Неопределено Тогда
		ПериодНачало = НачалоГода(ТекущаяДата());
	КонецЕсли;
	Если ПериодКонец = Неопределено Тогда
		ПериодКонец = КонецДня(ТекущаяДата());
	КонецЕсли;

	Менеджер = ЛогикаЗаказов.ПолучитьТекущегоСотрудника();
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Заказ.Ссылка КАК Заказ,
	|	Заказ.Дата КАК Дата,
	|	Заказ.Номер КАК Номер,
	|	Заказ.Заказчик КАК Заказчик,
	|	Заказ.СтатусЗаказа КАК СтатусЗаказа,
	|	Заказ.СуммаЗаказаРуб КАК СуммаЗаказаРуб
	|ИЗ
	|	Документ.Заказ КАК Заказ
	|ГДЕ
	|	Заказ.Дата МЕЖДУ &Начало И &Конец
	|	И (&Менеджер ЕСТЬ NULL ИЛИ Заказ.Менеджер = &Менеджер)
	|УПОРЯДОЧИТЬ ПО
	|	Заказ.Дата УБЫВ";
	Запрос.УстановитьПараметр("Начало", ПериодНачало);
	Запрос.УстановитьПараметр("Конец", ПериодКонец);
	Запрос.УстановитьПараметр("Менеджер", ?(ЗначениеЗаполнено(Менеджер), Менеджер, Неопределено));

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции
