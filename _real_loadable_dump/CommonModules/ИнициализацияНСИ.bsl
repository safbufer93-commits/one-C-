Процедура ЗаполнитьБазовыеСтатусы() Экспорт

	ОписанияСтатусов = Новый Массив;

	// Категория "Заказ" (базовая + процессная модель согласования).
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "Черновик", 5, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "НаСогласовании", 10, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "НужныПравки", 15, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "Утвержден", 20, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "ЗакупкаПодтверждена", 30, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "ВЛогистике", 40, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "ФинальнаяСправкаСформирована", 50, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "Закрыт", 60, Истина);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "Не заказан", 70, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "Заказан", 80, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "Не отправлен", 90, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "В пути", 100, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "Получен, нет УПД", 110, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "Завершен", 120, Истина);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "Заказ не оплачен", 130, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Заказ, "Заказ оплачен", 140, Ложь);

	// Категория "Оплата".
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Оплата, "Не оплачено", 10, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Оплата, "Долг", 20, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Оплата, "Оплачено", 30, Истина);

	// Категория "Доставка".
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Доставка, "Не отправлен", 10, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Доставка, "В пути", 20, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Доставка, "Получен", 30, Ложь);
	ДобавитьОписаниеСтатуса(ОписанияСтатусов, Перечисления.КатегорияСтатуса.Доставка, "Завершен", 40, Истина);

	Для Каждого Описание Из ОписанияСтатусов Цикл
		СтатусСсылка = НайтиСтатусПоКатегорииИНаименованию(Описание.Категория, Описание.Наименование);
		Если СтатусСсылка.Пустая() Тогда
			ОбъектСтатуса = Справочники.Статусы.СоздатьЭлемент();
			ОбъектСтатуса.Наименование = Описание.Наименование;
		Иначе
			ОбъектСтатуса = СтатусСсылка.ПолучитьОбъект();
		КонецЕсли;

		ОбъектСтатуса.Категория = Описание.Категория;
		ОбъектСтатуса.Порядок = Описание.Порядок;
		ОбъектСтатуса.Финальный = Описание.Финальный;
		ОбъектСтатуса.Записать();
	КонецЦикла;

	ЗаполнитьБазовыеПереходыСтатусов();

КонецПроцедуры

Процедура ЗаполнитьБазовыеСправочники() Экспорт
	// На текущем этапе — инициализация единого справочника статусов и переходов.
	ЗаполнитьБазовыеСтатусы();
КонецПроцедуры

Процедура ЗаполнитьБазовыеПереходыСтатусов() Экспорт

	Переходы = Новый Массив;

	// Обязательная цепочка согласования для категории "Заказ".
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Заказ, "Черновик", "НаСогласовании");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Заказ, "НаСогласовании", "Утвержден");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Заказ, "НаСогласовании", "НужныПравки");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Заказ, "НужныПравки", "НаСогласовании");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Заказ, "Утвержден", "ЗакупкаПодтверждена");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Заказ, "ЗакупкаПодтверждена", "ВЛогистике");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Заказ, "ВЛогистике", "ФинальнаяСправкаСформирована");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Заказ, "ФинальнаяСправкаСформирована", "Закрыт");

	// Базовые переходы для оплаты.
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Оплата, "Не оплачено", "Долг");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Оплата, "Не оплачено", "Оплачено");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Оплата, "Долг", "Оплачено");

	// Базовые переходы для доставки.
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Доставка, "Не отправлен", "В пути");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Доставка, "В пути", "Получен");
	ДобавитьОписаниеПерехода(Переходы, Перечисления.КатегорияСтатуса.Доставка, "Получен", "Завершен");

	НаборЗаписей = РегистрыСведений.ПереходыСтатусов.СоздатьНаборЗаписей();
	НаборЗаписей.Прочитать();
	НаборЗаписей.Очистить();

	Для Каждого Описание Из Переходы Цикл
		СтатусИсточник = НайтиСтатусПоКатегорииИНаименованию(Описание.Категория, Описание.СтатусИсточник);
		СтатусНазначение = НайтиСтатусПоКатегорииИНаименованию(Описание.Категория, Описание.СтатусНазначение);
		Если СтатусИсточник.Пустая() ИЛИ СтатусНазначение.Пустая() Тогда
			Продолжить;
		КонецЕсли;

		Запись = НаборЗаписей.Добавить();
		Запись.Категория = Описание.Категория;
		Запись.СтатусИсточник = СтатусИсточник;
		Запись.СтатусНазначение = СтатусНазначение;
		Запись.Разрешен = Истина;
		Запись.Комментарий = "Базовый переход";
	КонецЦикла;

	НаборЗаписей.Записать();

КонецПроцедуры

Процедура ДобавитьОписаниеСтатуса(МассивОписаний, Категория, Наименование, Порядок, Финальный)
	Описание = Новый Структура("Категория,Наименование,Порядок,Финальный", Категория, Наименование, Порядок, Финальный);
	МассивОписаний.Добавить(Описание);
КонецПроцедуры

Процедура ДобавитьОписаниеПерехода(МассивПереходов, Категория, СтатусИсточник, СтатусНазначение)
	Описание = Новый Структура("Категория,СтатусИсточник,СтатусНазначение", Категория, СтатусИсточник, СтатусНазначение);
	МассивПереходов.Добавить(Описание);
КонецПроцедуры

Функция НайтиСтатусПоКатегорииИНаименованию(Категория, Наименование)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Статусы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Статусы КАК Статусы
	|ГДЕ
	|	Статусы.Категория = &Категория
	|	И Статусы.Наименование = &Наименование";
	Запрос.УстановитьПараметр("Категория", Категория);
	Запрос.УстановитьПараметр("Наименование", Наименование);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Справочники.Статусы.ПустаяСсылка();

КонецФункции
