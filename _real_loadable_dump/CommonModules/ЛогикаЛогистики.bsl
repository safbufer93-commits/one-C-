Процедура РассчитатьПлановыеДаты(СсылкаНаОтправку) Экспорт

	ОтправкаОбъект = ПолучитьОбъектОтправки(СсылкаНаОтправку);
	Если ОтправкаОбъект = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ОтправкаОбъект.ПланДатаОтправки) Тогда
		ОтправкаОбъект.ПланДатаОтправки = НачалоДня(ТекущаяДата());
	КонецЕсли;

	НормативДней = 0;
	Если ЗначениеЗаполнено(ОтправкаОбъект.МаршрутДоставки) Тогда
		Попытка
			НормативДней = ОтправкаОбъект.МаршрутДоставки.НормативДней;
		Исключение
			ПротоколироватьИсключение("Не удалось получить норматив дней из маршрута доставки", ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;

	Если НормативДней = 0 И ЗначениеЗаполнено(ОтправкаОбъект.МаршрутДоставки) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	МАКСИМУМ(Точки.ПланДней) КАК НормативДней
		|ИЗ
		|	Справочник.МаршрутыДоставки.Точки КАК Точки
		|ГДЕ
		|	Точки.Ссылка = &Маршрут";
		Запрос.УстановитьПараметр("Маршрут", ОтправкаОбъект.МаршрутДоставки);

		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.НормативДней) Тогда
			НормативДней = Выборка.НормативДней;
		КонецЕсли;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ОтправкаОбъект.ПланДатаПрибытия) Тогда
		ОтправкаОбъект.ПланДатаПрибытия = ОтправкаОбъект.ПланДатаОтправки + НормативДней * 24 * 60 * 60;
	КонецЕсли;

КонецПроцедуры

Процедура СоздатьЭтапыМаршрута(СсылкаНаОтправку, Маршрут = Неопределено) Экспорт

	ОтправкаОбъект = ПолучитьОбъектОтправки(СсылкаНаОтправку);
	Если ОтправкаОбъект = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Маршрут) Тогда
		Маршрут = ОтправкаОбъект.МаршрутДоставки;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Маршрут) Тогда
		Возврат;
	КонецЕсли;

	НаборЗаписей = РегистрыСведений.ЭтапыДоставки.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Отправка.Установить(ОтправкаОбъект.Ссылка);
	НаборЗаписей.Прочитать();
	НаборЗаписей.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Точки.Порядок КАК Порядок,
	|	Точки.ТочкаМаршрута КАК ТочкаМаршрута,
	|	Точки.ПланДней КАК ПланДней,
	|	Точки.КомментарийТочки КАК КомментарийТочки
	|ИЗ
	|	Справочник.МаршрутыДоставки.Точки КАК Точки
	|ГДЕ
	|	Точки.Ссылка = &Маршрут
	|УПОРЯДОЧИТЬ ПО
	|	Точки.Порядок";
	Запрос.УстановитьПараметр("Маршрут", Маршрут);

	Выборка = Запрос.Выполнить().Выбрать();
	ПлановаяДата = ОтправкаОбъект.ПланДатаОтправки;
	Если НЕ ЗначениеЗаполнено(ПлановаяДата) Тогда
		ПлановаяДата = НачалоДня(ТекущаяДата());
	КонецЕсли;

	Пока Выборка.Следующий() Цикл
		Запись = НаборЗаписей.Добавить();
		Попытка
			Запись.Период = ТекущаяДата();
		Исключение
			ПротоколироватьИсключение("Не удалось установить период этапа доставки", ОписаниеОшибки());
		КонецПопытки;

		Запись.Отправка = ОтправкаОбъект.Ссылка;
		Запись.ТочкаМаршрута = Выборка.ТочкаМаршрута;
		Запись.Порядок = Выборка.Порядок;
		Запись.ПланДата = ПлановаяДата + Выборка.ПланДней * 24 * 60 * 60;
		Запись.СтатусЭтапа = Перечисления.СтатусЭтапаДоставки.План;
		Запись.Комментарий = Выборка.КомментарийТочки;
	КонецЦикла;

	НаборЗаписей.Записать();

КонецПроцедуры

Функция РассчитатьСтоимостьОтправки(СсылкаНаОтправку) Экспорт

	ОтправкаОбъект = ПолучитьОбъектОтправки(СсылкаНаОтправку);
	Если ОтправкаОбъект = Неопределено Тогда
		Возврат 0;
	КонецЕсли;

	ПланВалюта = 0;
	ФактРуб = 0;
	Для Каждого СтрокаПозиции Из ОтправкаОбъект.Позиции Цикл
		ПланВалюта = ПланВалюта + СтрокаПозиции.ДоставкаВалюта;
		ФактРуб = ФактРуб + СтрокаПозиции.ДоставкаРуб;
	КонецЦикла;

	ОтправкаОбъект.ПланСтоимостьДоставки = ПланВалюта;
	Если ЗначениеЗаполнено(ОтправкаОбъект.СтоимостьПеревозкиРуб) И ОтправкаОбъект.СтоимостьПеревозкиРуб > 0 Тогда
		ФактРуб = ОтправкаОбъект.СтоимостьПеревозкиРуб;
	Иначе
		ОтправкаОбъект.СтоимостьПеревозкиРуб = ФактРуб;
	КонецЕсли;

	Возврат ФактРуб;

КонецФункции

Процедура ПересчитатьЛогистическуюСумму(СсылкаНаОтправку) Экспорт
	РассчитатьСтоимостьОтправки(СсылкаНаОтправку);
КонецПроцедуры

Процедура ЗаписатьСобытиеТрекинга(Отправка, ТипСобытия, Описание, Местоположение = "", Комментарий = "", ИсточникДанных = "РучнойВвод") Экспорт

	Если НЕ ЗначениеЗаполнено(Отправка) Тогда
		Возврат;
	КонецЕсли;

	НаборЗаписей = РегистрыСведений.СобытияТрекинга.СоздатьНаборЗаписей();
	Запись = НаборЗаписей.Добавить();
	Попытка
		Запись.Период = ТекущаяДата();
	Исключение
		ПротоколироватьИсключение("Не удалось установить период события трекинга", ОписаниеОшибки());
	КонецПопытки;

	Запись.Отправка = Отправка;
	Запись.ТипСобытия = ТипСобытия;
	Запись.Описание = Описание;
	Запись.Местоположение = Местоположение;
	Запись.ИсточникДанных = ИсточникДанных;
	Запись.Комментарий = Комментарий;
	НаборЗаписей.Записать();

КонецПроцедуры

Процедура ПроверитьПравилоФактБольшеПлана(ОтправкаОбъект, Отказ) Экспорт

	Если ОтправкаОбъект.СтоимостьПеревозкиРуб <= ОтправкаОбъект.ПланСтоимостьДоставки Тогда
		Возврат;
	КонецЕсли;

	ТекстОбъяснения = "";
	Попытка
		ТекстОбъяснения = СокрЛП(ОтправкаОбъект.ОбъяснениеПревышения);
	Исключение
		ПротоколироватьИсключение("Не удалось прочитать поле объяснения превышения логистики", ОписаниеОшибки());
	КонецПопытки;

	Если ПустаяСтрока(ТекстОбъяснения) Тогда
		ТекстОбъяснения = СокрЛП(ОтправкаОбъект.Комментарий);
	КонецЕсли;

	Если ПустаяСтрока(ТекстОбъяснения) Тогда
		Сообщить("Факт логистики превышает план. Для продолжения заполните поле объяснения.");
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры

Функция ПолучитьОбъектОтправки(СсылкаИлиОбъект)

	Если ТипЗнч(СсылкаИлиОбъект) = Тип("ДокументОбъект.Отправка") Тогда
		Возврат СсылкаИлиОбъект;
	КонецЕсли;

	Если ТипЗнч(СсылкаИлиОбъект) = Тип("ДокументСсылка.Отправка") Тогда
		Возврат СсылкаИлиОбъект.ПолучитьОбъект();
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Процедура ПротоколироватьИсключение(Контекст, ТекстОшибки)
	ЗаписьЖурналаРегистрации(
		"ЛогикаЛогистики",
		УровеньЖурналаРегистрации.Ошибка,
		,
		,
		Контекст + ": " + ТекстОшибки);
КонецПроцедуры
