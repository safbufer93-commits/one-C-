Процедура ПротоколироватьИсключение(Контекст, ТекстОшибки)
	ЗаписьЖурналаРегистрации(
		"ЛогикаЗаказов",
		УровеньЖурналаРегистрации.Ошибка,
		,
		,
		Контекст + ": " + ТекстОшибки);
