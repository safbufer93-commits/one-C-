// ============================================================
// ОБЩИЙ МОДУЛЬ: ЛогикаЗаказов
// Назначение: расчеты, проверки, согласование, вложения
// ============================================================

#Область РасчетыЗаказа

Процедура ПересчитатьЗаказ(ЗаказОбъект, ДатаРасчета = Неопределено) Экспорт

	Если ДатаРасчета = Неопределено Тогда
		ДатаРасчета = ТекущаяДата();
	КонецЕсли;

	ИтогоПланПозиции = 0;     // planned_items_sum
	ИтогоПланНетто = 0;       // planned_net
	ИтогоПланНДС = 0;         // planned_VAT
	ИтогоПланСНДС = 0;        // planned_total_with_VAT
	ИтогоФактНетто = 0;       // actual_net
	ИтогоПродажи = 0;
	ИтогоПрибыль = 0;
	ОбщийВес = 0;
	ОбщийОбъемныйВес = 0;

	НомерПозиции = 0;
	Для Каждого СтрокаПозиции Из ЗаказОбъект.Позиции Цикл
		НомерПозиции = НомерПозиции + 1;

		Количество = ?(СтрокаПозиции.Количество > 0, СтрокаПозиции.Количество, 0);
		ЦенаВалюта = ?(СтрокаПозиции.ЦенаДилераВалюта > 0, СтрокаПозиции.ЦенаДилераВалюта, 0);
		Курс = ?(СтрокаПозиции.КурсВалюты > 0, СтрокаПозиции.КурсВалюты, 1);

		ВесФакт = ?(СтрокаПозиции.ВесФакт > 0, СтрокаПозиции.ВесФакт, 0);
		ВесОбъемный = РассчитатьОбъемныйВес(
			?(СтрокаПозиции.Длина > 0, СтрокаПозиции.Длина, 0),
			?(СтрокаПозиции.Ширина > 0, СтрокаПозиции.Ширина, 0),
			?(СтрокаПозиции.Высота > 0, СтрокаПозиции.Высота, 0),
			Количество);
		СтрокаПозиции.ВесОбъемный = ВесОбъемный;

		РасчетныйВес = Макс(ВесФакт * Количество, ВесОбъемный);

		ПланДоставкаВалюта = РассчитатьПлановуюДоставку(СтрокаПозиции, РасчетныйВес, ВесОбъемный);
		СтрокаПозиции.ПланСтоимостьДоставки = ПланДоставкаВалюта;
		ФактДоставкаВалюта = ?(СтрокаПозиции.ФактСтоимостьДоставки > 0, СтрокаПозиции.ФактСтоимостьДоставки, ПланДоставкаВалюта);

		ПланПозицииРуб = ЦенаВалюта * Количество * Курс;
		ПланНеттоРуб = ПланПозицииРуб + ПланДоставкаВалюта * Курс;

		СтавкаПошлины = ?(СтрокаПозиции.ПроцентПошлины > 0, СтрокаПозиции.ПроцентПошлины, 0);
		СтавкаНДС = ?(СтрокаПозиции.СтавкаНДСВвоз > 0, СтрокаПозиции.СтавкаНДСВвоз, 0);
		СтавкаКомиссии = ?(СтрокаПозиции.ПроцентКомиссии > 0, СтрокаПозиции.ПроцентКомиссии, СтрокаПозиции.КомиссияОплатыПроцент);

		СуммаПошлины = ПланНеттоРуб * СтавкаПошлины / 100;
		СуммаНДС = (ПланНеттоРуб + СуммаПошлины) * СтавкаНДС / 100;
		СуммаКомиссии = ПланНеттоРуб * СтавкаКомиссии / 100;

		СебестоимостьРуб = ПланНеттоРуб + СуммаПошлины + СуммаНДС + СуммаКомиссии;
		ФактНеттоРуб = (ЦенаВалюта * Количество * Курс) + (ФактДоставкаВалюта * Курс) + СуммаПошлины + СуммаНДС + СуммаКомиссии;

		СтрокаПозиции.СуммаПошлины = СуммаПошлины;
		СтрокаПозиции.СуммаНДСВвоз = СуммаНДС;
		СтрокаПозиции.СуммаКомиссии = СуммаКомиссии;
		СтрокаПозиции.ЦенаИтогРуб = ?(Количество = 0, 0, СебестоимостьРуб / Количество);
		СтрокаПозиции.ИтоговаяСуммаРуб = СебестоимостьРуб;

		Если СтрокаПозиции.РыночнаяЦена > 0 Тогда
			ПрибыльНаЕдиницу = СтрокаПозиции.РыночнаяЦена - СтрокаПозиции.ЦенаИтогРуб;
		Иначе
			ПрибыльНаЕдиницу = СтрокаПозиции.ЦенаИтогРуб * ?(СтрокаПозиции.ПроцентМаржи > 0, СтрокаПозиции.ПроцентМаржи, 0) / 100;
		КонецЕсли;

		СтрокаПозиции.ПрибыльНаЕдиницу = ПрибыльНаЕдиницу;
		СтрокаПозиции.ПрибыльСумма = ПрибыльНаЕдиницу * Количество;
		СтрокаПозиции.ЦенаПродажиИП6 = СтрокаПозиции.ЦенаИтогРуб + ПрибыльНаЕдиницу;
		СтрокаПозиции.ЦенаПродажиИП7 = СтрокаПозиции.ЦенаПродажиИП6 * 1.05;
		СтрокаПозиции.ЦенаПродажиООО = СтрокаПозиции.ЦенаПродажиИП6 * 1.22;
		СтрокаПозиции.ЦенаПродажиИП13 = СтрокаПозиции.ЦенаПродажиООО;

		Если СтрокаПозиции.РыночнаяЦена > 0 Тогда
			ИтогоПродажи = ИтогоПродажи + СтрокаПозиции.РыночнаяЦена * Количество;
		Иначе
			ИтогоПродажи = ИтогоПродажи + СтрокаПозиции.ЦенаПродажиИП6 * Количество;
		КонецЕсли;

		ИтогоПланПозиции = ИтогоПланПозиции + ПланПозицииРуб;
		ИтогоПланНетто = ИтогоПланНетто + ПланНеттоРуб;
		ИтогоПланНДС = ИтогоПланНДС + СуммаНДС;
		ИтогоПланСНДС = ИтогоПланСНДС + (ПланНеттоРуб + СуммаНДС);
		ИтогоФактНетто = ИтогоФактНетто + ФактНеттоРуб;
		ИтогоПрибыль = ИтогоПрибыль + СтрокаПозиции.ПрибыльСумма;

		ОбщийВес = ОбщийВес + ВесФакт * Количество;
		ОбщийОбъемныйВес = ОбщийОбъемныйВес + ВесОбъемный;

		ЗаписатьИсториюРасчетаПозиции(ЗаказОбъект, НомерПозиции, СтрокаПозиции, ДатаРасчета, ПланПозицииРуб, ПланНеттоРуб, ФактНеттоРуб, РасчетныйВес);
	КонецЦикла;

	Дельта = ИтогоФактНетто - ИтогоПланСНДС;                // delta
	ВаловаяПрибыль = ИтогоПродажи - ИтогоФактНетто;         // gross_profit
	НалогНаПрибыль = ?(ВаловаяПрибыль > 0, ВаловаяПрибыль * 0.20, 0); // tax_on_profit
	ЧистаяПрибыль = ВаловаяПрибыль - НалогНаПрибыль;        // net_profit
	МаржаИтог = ?(ИтогоФактНетто = 0, 0, ЧистаяПрибыль / ИтогоФактНетто * 100); // margin_%

	ЗаказОбъект.СуммаЗаказаРуб = ИтогоПланСНДС;
	ЗаказОбъект.СуммаМаржиРуб = ЧистаяПрибыль;
	ЗаказОбъект.МаржаПроцент = МаржаИтог;

	Попытка
		ЗаказОбъект.ОбщийВес = ОбщийВес;
		ЗаказОбъект.ОбщийОбъемныйВес = ОбщийОбъемныйВес;
	Исключение
		ПротоколироватьИсключение("Не удалось записать итоговый вес заказа", ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

Функция РассчитатьОбъемныйВес(Длина, Ширина, Высота, Количество = 1) Экспорт
	Если Количество <= 0 Тогда
		Возврат 0;
	КонецЕсли;
	Возврат (Длина * Ширина * Высота) / 6000 * Количество;
КонецФункции

Функция РассчитатьПлановуюДоставку(СтрокаПозиции, РасчетныйВес, ВесОбъемный)

	Если СтрокаПозиции.ТипДоставки = Перечисления.ТипДоставки.ОАЭАвиаСТаможней
		ИЛИ СтрокаПозиции.ТипДоставки = Перечисления.ТипДоставки.ОАЭАвиаБезТаможни Тогда
		Возврат Макс(РасчетныйВес * 10, ВесОбъемный * 5);
	КонецЕсли;

	Если СтрокаПозиции.ТипДоставки = Перечисления.ТипДоставки.Польша3дня Тогда
		Возврат 15 * СтрокаПозиции.Количество;
	КонецЕсли;

	Если ЗначениеЗаполнено(СтрокаПозиции.ПланСтоимостьДоставки) И СтрокаПозиции.ПланСтоимостьДоставки > 0 Тогда
		Возврат СтрокаПозиции.ПланСтоимостьДоставки;
	КонецЕсли;

	Возврат 0;

КонецФункции

Процедура ЗаписатьИсториюРасчетаПозиции(ЗаказОбъект, НомерПозиции, СтрокаПозиции, ДатаРасчета, ПланПозицииРуб, ПланНеттоРуб, ФактНеттоРуб, РасчетныйВес)

	Если НЕ ЗначениеЗаполнено(ЗаказОбъект.Ссылка) Тогда
		Возврат;
	КонецЕсли;

	Набор = РегистрыСведений.ИсторияРасчетовПозицииЗаказа.СоздатьНаборЗаписей();
	Запись = Набор.Добавить();
	Попытка
		Запись.Период = ДатаРасчета;
	Исключение
		ПротоколироватьИсключение("Не удалось установить период записи истории расчета позиции", ОписаниеОшибки());
	КонецПопытки;

	Запись.Заказ = ЗаказОбъект.Ссылка;
	Запись.НомерПозиции = НомерПозиции;
	Запись.ИдентификаторРасчета = Строка(Новый УникальныйИдентификатор);
	Запись.Товар = СтрокаПозиции.Товар;
	Запись.Поставщик = СтрокаПозиции.Поставщик;
	Запись.ТипДоставки = СтрокаПозиции.ТипДоставки;
	Запись.ФормаОплаты = ЗаказОбъект.ФормаОплаты;

	Запись.Количество = СтрокаПозиции.Количество;
	Запись.ЦенаДилераВалюта = СтрокаПозиции.ЦенаДилераВалюта;
	Запись.КурсВалюты = СтрокаПозиции.КурсВалюты;
	Запись.ЗакупкаРубВсего = ПланПозицииРуб;
	Запись.ВесФакт = СтрокаПозиции.ВесФакт;
	Запись.ВесОбъемный = СтрокаПозиции.ВесОбъемный;
	Запись.РасчетныйВес = РасчетныйВес;
	Запись.ДоставкаВалюта = СтрокаПозиции.ПланСтоимостьДоставки;
	Запись.ДоставкаРуб = СтрокаПозиции.ПланСтоимостьДоставки * ?(СтрокаПозиции.КурсВалюты = 0, 1, СтрокаПозиции.КурсВалюты);
	Запись.СтавкаПошлины = СтрокаПозиции.ПроцентПошлины;
	Запись.СуммаПошлины = СтрокаПозиции.СуммаПошлины;
	Запись.СтавкаНДСВвоз = СтрокаПозиции.СтавкаНДСВвоз;
	Запись.СуммаНДСВвоз = СтрокаПозиции.СуммаНДСВвоз;
	Запись.КомиссияОплатыПроцент = СтрокаПозиции.КомиссияОплатыПроцент;
	Запись.СуммаКомиссии = СтрокаПозиции.СуммаКомиссии;
	Запись.ПрибыльНаЕдиницу = СтрокаПозиции.ПрибыльНаЕдиницу;
	Запись.ПрибыльСумма = СтрокаПозиции.ПрибыльСумма;
	Запись.СебестоимостьЕдБезНДС = СтрокаПозиции.ЦенаИтогРуб;
	Запись.СебестоимостьЕдСНДС = ?(СтрокаПозиции.Количество = 0, 0, ФактНеттоРуб / СтрокаПозиции.Количество);
	Запись.ЦенаПродажиООО = СтрокаПозиции.ЦенаПродажиООО;
	Запись.ЦенаПродажиИП13 = СтрокаПозиции.ЦенаПродажиИП13;
	Запись.ЦенаПродажиИП7 = СтрокаПозиции.ЦенаПродажиИП7;
	Запись.ЦенаПродажиИП6 = СтрокаПозиции.ЦенаПродажиИП6;
	Запись.ИспользованВЗаказе = Истина;
	Запись.АвторРасчета = ПолучитьТекущегоСотрудника();
	Запись.Комментарий = "Автоматический расчет заказа";
	Набор.Записать();

КонецПроцедуры

#КонецОбласти

#Область Проверки

Процедура ПроверитьЗаполнениеЗаказа(ЗаказОбъект, Отказ, ТекстОшибки = "") Экспорт

	Ошибки = Новый Массив;

	Если НЕ ЗначениеЗаполнено(ЗаказОбъект.Заказчик) Тогда
		Ошибки.Добавить("Не заполнен заказчик.");
	КонецЕсли;

	Если ПустаяСтрока(СокрЛП(ЗаказОбъект.Номер)) Тогда
		Ошибки.Добавить("Номер заказа не может быть пустым.");
	ИначеЕсли НЕ НомерЗаказаУникален(ЗаказОбъект) Тогда
		Ошибки.Добавить("Номер заказа должен быть уникальным.");
	КонецЕсли;

	Если ЗаказОбъект.Позиции.Количество() = 0 Тогда
		Ошибки.Добавить("В заказе должна быть минимум одна позиция.");
	КонецЕсли;

	Для Каждого СтрокаПозиции Из ЗаказОбъект.Позиции Цикл
		Если СтрокаПозиции.Количество <= 0 Тогда
			Ошибки.Добавить("Количество в позиции должно быть больше нуля.");
			Прервать;
		КонецЕсли;
		Если СтрокаПозиции.ЦенаДилераВалюта <= 0 Тогда
			Ошибки.Добавить("Цена в валюте в позиции должна быть больше нуля.");
			Прервать;
		КонецЕсли;
		Если СтрокаПозиции.ПроцентПошлины < 0 ИЛИ СтрокаПозиции.ПроцентПошлины > 100 Тогда
			Ошибки.Добавить("Ставка пошлины должна быть в диапазоне 0..100.");
			Прервать;
		КонецЕсли;
		Если СтрокаПозиции.СтавкаНДСВвоз < 0 ИЛИ СтрокаПозиции.СтавкаНДСВвоз > 100 Тогда
			Ошибки.Добавить("Ставка НДС должна быть в диапазоне 0..100.");
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Ошибки.Количество() > 0 Тогда
		Отказ = Истина;
		ТекстОшибки = СтрСоединить(Ошибки, Символы.ПС);
		Сообщить(ТекстОшибки);
	КонецЕсли;

КонецПроцедуры

Функция НомерЗаказаУникален(ЗаказОбъект)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Заказ.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Заказ КАК Заказ
	|ГДЕ
	|	Заказ.Номер = &Номер
	|	И Заказ.Ссылка <> &Ссылка";
	Запрос.УстановитьПараметр("Номер", ЗаказОбъект.Номер);
	Запрос.УстановитьПараметр("Ссылка", ЗаказОбъект.Ссылка);

	Возврат Запрос.Выполнить().Пустой();

КонецФункции

#КонецОбласти

#Область Согласование

Процедура СохранитьЧерновик(ЗаказОбъект, Комментарий = "") Экспорт
	УстановитьСтатусЗаказа(ЗаказОбъект, "Черновик", Комментарий);
КонецПроцедуры

Процедура ОтправитьНаСогласование(ЗаказОбъект, Комментарий = "") Экспорт
	УстановитьСтатусЗаказа(ЗаказОбъект, "НаСогласовании", Комментарий, Перечисления.РольПользователя.Менеджер);
КонецПроцедуры

Процедура Утвердить(ЗаказОбъект, Комментарий = "") Экспорт
	УстановитьСтатусЗаказа(ЗаказОбъект, "Утвержден", Комментарий, Перечисления.РольПользователя.Руководитель);
КонецПроцедуры

Процедура ВернутьНаПравки(ЗаказОбъект, Комментарий) Экспорт
	УстановитьСтатусЗаказа(ЗаказОбъект, "НужныПравки", Комментарий, Перечисления.РольПользователя.Руководитель);
КонецПроцедуры

Процедура УстановитьСтатусЗаказа(ЗаказОбъект, НаименованиеНовогоСтатуса, Комментарий = "", РольПользователя = Неопределено) Экспорт

	НовыйСтатус = НайтиСтатус(Перечисления.КатегорияСтатуса.Заказ, НаименованиеНовогоСтатуса);
	Если НовыйСтатус.Пустая() Тогда
		ИнициализацияНСИ.ЗаполнитьБазовыеСтатусы();
		НовыйСтатус = НайтиСтатус(Перечисления.КатегорияСтатуса.Заказ, НаименованиеНовогоСтатуса);
	КонецЕсли;
	Если НовыйСтатус.Пустая() Тогда
		ВызватьИсключение "Не найден статус """ + НаименованиеНовогоСтатуса + """ в категории Заказ.";
	КонецЕсли;

	СтарыйСтатус = ЗаказОбъект.СтатусЗаказа;
	Если НЕ ЛогикаСтатусов.ПроверитьПереходСтатуса(Перечисления.КатегорияСтатуса.Заказ, СтарыйСтатус, НовыйСтатус, РольПользователя) Тогда
		ВызватьИсключение "Переход статуса """ + Строка(СтарыйСтатус) + """ → """ + Строка(НовыйСтатус) + """ запрещен.";
	КонецЕсли;

	ЗаказОбъект.СтатусЗаказа = НовыйСтатус;

	Если ЗначениеЗаполнено(ЗаказОбъект.Ссылка) Тогда
		ЛогикаСтатусов.ЗаписатьИсториюСтатуса(
			ЗаказОбъект.Ссылка,
			Неопределено,
			Перечисления.КатегорияСтатуса.Заказ,
			СтарыйСтатус,
			НовыйСтатус,
			ПолучитьТекущегоСотрудника(),
			Комментарий);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область Вложения

Процедура ЗарегистрироватьВложениеДокумента(ДокументРегистрации) Экспорт

	НаборЗаписей = РегистрыСведений.ДокументыВложения.СоздатьНаборЗаписей();
	Попытка
		НаборЗаписей.Отбор.ДокументРегистрации.Установить(ДокументРегистрации.Ссылка);
	Исключение
		ПротоколироватьИсключение("Не удалось установить отбор по документу регистрации вложения", ОписаниеОшибки());
	КонецПопытки;
	НаборЗаписей.Прочитать();
	НаборЗаписей.Очистить();

	Запись = НаборЗаписей.Добавить();
	Попытка
		Запись.Период = ДокументРегистрации.Дата;
	Исключение
		ПротоколироватьИсключение("Не удалось установить период в регистре ДокументыВложения", ОписаниеОшибки());
	КонецПопытки;

	Запись.ТипДокумента = ДокументРегистрации.ТипДокумента;
	Запись.Заказ = ДокументРегистрации.Заказ;
	Запись.Отправка = ДокументРегистрации.Отправка;
	Запись.НомерДокумента = ДокументРегистрации.НомерДокумента;
	Запись.ДатаДокумента = ДокументРегистрации.ДатаДокумента;
	Запись.URL = ДокументРегистрации.Файл;
	Запись.Комментарий = ДокументРегистрации.Комментарий;
	Попытка
		Запись.ДокументРегистрации = ДокументРегистрации.Ссылка;
	Исключение
		ПротоколироватьИсключение("Не удалось заполнить реквизит ДокументРегистрации в регистре ДокументыВложения", ОписаниеОшибки());
	КонецПопытки;
	Попытка
		Запись.Автор = ПолучитьТекущегоСотрудника();
	Исключение
		ПротоколироватьИсключение("Не удалось заполнить автора вложения", ОписаниеОшибки());
	КонецПопытки;

	НаборЗаписей.Записать();

КонецПроцедуры

#КонецОбласти

#Область Служебное

Функция НайтиСтатус(Категория, Наименование)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Статусы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Статусы КАК Статусы
	|ГДЕ
	|	Статусы.Категория = &Категория
	|	И Статусы.Наименование = &Наименование";
	Запрос.УстановитьПараметр("Категория", Категория);
	Запрос.УстановитьПараметр("Наименование", Наименование);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Справочники.Статусы.ПустаяСсылка();

КонецФункции

Функция ПолучитьТекущегоСотрудника() Экспорт

	Возврат ЛогикаСтатусов.ПолучитьТекущегоСотрудника();

