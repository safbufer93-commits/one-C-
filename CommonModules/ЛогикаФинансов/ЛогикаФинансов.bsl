Процедура ЗарегистрироватьОплату(ДокументОплаты) Экспорт

	Если НЕ ЗначениеЗаполнено(ДокументОплаты.Заказ) Тогда
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ДокументОплаты.СуммаРуб) Тогда
		ДокументОплаты.СуммаРуб = ДокументОплаты.Сумма * ?(ДокументОплаты.КурсВалюты = 0, 1, ДокументОплаты.КурсВалюты);
	КонецЕсли;

	НаборЗаписей = РегистрыСведений.ФинансыЗаказов.СоздатьНаборЗаписей();
	Попытка
		НаборЗаписей.Отбор.ДокументОплаты.Установить(ДокументОплаты.Ссылка);
	Исключение
		ПротоколироватьИсключение("Не удалось установить отбор регистра ФинансыЗаказов по документу оплаты", ОписаниеОшибки());
	КонецПопытки;
	НаборЗаписей.Прочитать();
	НаборЗаписей.Очистить();

	Запись = НаборЗаписей.Добавить();
	Попытка
		Запись.Период = ДокументОплаты.Дата;
	Исключение
		ПротоколироватьИсключение("Не удалось установить период записи ФинансыЗаказов", ОписаниеОшибки());
	КонецПопытки;

	Запись.Заказ = ДокументОплаты.Заказ;
	Запись.ВидОплаты = ДокументОплаты.ВидОплаты;
	Запись.Сумма = ДокументОплаты.Сумма;
	Запись.СуммаРуб = ДокументОплаты.СуммаРуб;
	Запись.СтатусОплаты = ДокументОплаты.СтатусОплаты;
	Запись.Валюта = ДокументОплаты.Валюта;
	Запись.ДатаПлан = ДокументОплаты.ДатаОплатыПлан;
	Запись.ДатаФакт = ДокументОплаты.ДатаОплатыФакт;
	Запись.КонтрагентЗаказчик = ДокументОплаты.КонтрагентЗаказчик;

	Попытка
		Запись.ДокументОплаты = ДокументОплаты.Ссылка;
	Исключение
		ПротоколироватьИсключение("Не удалось заполнить ссылку на документ оплаты в регистре ФинансыЗаказов", ОписаниеОшибки());
	КонецПопытки;

	НаборЗаписей.Записать();

	ПересчитатьОплатуИДолг(ДокументОплаты.Заказ);

КонецПроцедуры

Процедура ПересчитатьИтогиЗаказа(СсылкаНаЗаказ) Экспорт
	ПересчитатьОплатуИДолг(СсылкаНаЗаказ);
КонецПроцедуры

Функция ПересчитатьОплатуИДолг(СсылкаНаЗаказ) Экспорт

	Результат = Новый Структура("План,Оплачено,Остаток,СтатусОплаты", 0, 0, 0, Справочники.Статусы.ПустаяСсылка());
	Если НЕ ЗначениеЗаполнено(СсылкаНаЗаказ) Тогда
		Возврат Результат;
	КонецЕсли;

	ЗаказОбъект = СсылкаНаЗаказ.ПолучитьОбъект();
	План = ЗаказОбъект.СуммаЗаказаРуб;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СУММА(Финансы.СуммаРуб) КАК Оплачено
	|ИЗ
	|	РегистрСведений.ФинансыЗаказов КАК Финансы
	|ГДЕ
	|	Финансы.Заказ = &Заказ
	|	И Финансы.ВидОплаты = &ВидОплаты";
	Запрос.УстановитьПараметр("Заказ", СсылкаНаЗаказ);
	Запрос.УстановитьПараметр("ВидОплаты", Перечисления.ВидОплаты.ОтЗаказчика);

	Оплачено = 0;
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Оплачено) Тогда
		Оплачено = Выборка.Оплачено;
	КонецЕсли;

	Остаток = План - Оплачено;
	Если Остаток < 0 Тогда
		Остаток = 0;
	КонецЕсли;

	НаименованиеСтатуса = "Не оплачено";
	Если Оплачено <= 0 Тогда
		НаименованиеСтатуса = "Не оплачено";
	ИначеЕсли Остаток > 0 Тогда
		НаименованиеСтатуса = "Долг";
	Иначе
		НаименованиеСтатуса = "Оплачено";
	КонецЕсли;

	СтатусОплаты = НайтиСтатусОплаты(НаименованиеСтатуса);
	Если ЗначениеЗаполнено(СтатусОплаты) Тогда
		ЗаказОбъект.СтатусОплатыПоСчету = СтатусОплаты;
		ЗаказОбъект.Записать();
	КонецЕсли;

	Результат.План = План;
	Результат.Оплачено = Оплачено;
	Результат.Остаток = Остаток;
	Результат.СтатусОплаты = СтатусОплаты;

	Возврат Результат;

КонецФункции

Функция РассчитатьОстатокПоОплатам(СсылкаНаЗаказ) Экспорт
	Возврат ПересчитатьОплатуИДолг(СсылкаНаЗаказ).Остаток;
КонецФункции

Процедура СформироватьДвижениеДДС(ДокументОплаты) Экспорт
	// Регистр накопления включается при дальнейшем расширении метаданных движения.
	// На текущем этапе используем регистр ФинансыЗаказов как источник факта оплат.
КонецПроцедуры

Функция НайтиСтатусОплаты(НаименованиеСтатуса)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Статусы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Статусы КАК Статусы
	|ГДЕ
	|	Статусы.Категория = &Категория
	|	И Статусы.Наименование = &Наименование";
	Запрос.УстановитьПараметр("Категория", Перечисления.КатегорияСтатуса.Оплата);
	Запрос.УстановитьПараметр("Наименование", НаименованиеСтатуса);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Справочники.Статусы.ПустаяСсылка();

КонецФункции

Процедура ПротоколироватьИсключение(Контекст, ТекстОшибки)
	ЗаписьЖурналаРегистрации(
		"ЛогикаФинансов",
		УровеньЖурналаРегистрации.Ошибка,
		,
		,
		Контекст + ": " + ТекстОшибки);
КонецПроцедуры
