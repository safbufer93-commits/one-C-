Функция ОпределитьРольПользователя(ПользовательИБ) Экспорт

	Если ПользовательИБ = Неопределено Тогда
		Возврат Перечисления.РольПользователя.Менеджер;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Сотрудники.Роль КАК Роль
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Логин = &Логин";
	Запрос.УстановитьПараметр("Логин", ПользовательИБ.Имя);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Роль) Тогда
		Возврат Выборка.Роль;
	КонецЕсли;

	Возврат Перечисления.РольПользователя.Менеджер;

КонецФункции

Функция МожноИзменятьЗаказ(СсылкаНаЗаказ, ПользовательИБ) Экспорт

	Роль = ОпределитьРольПользователя(ПользовательИБ);
	Если Роль = Перечисления.РольПользователя.Администратор Тогда
		Возврат Истина;
	КонецЕсли;

	Если Роль = Перечисления.РольПользователя.Руководитель Тогда
		Возврат Истина;
	КонецЕсли;

	Если Роль = Перечисления.РольПользователя.Менеджер Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;

КонецФункции

Функция МожноПроводитьОплату(ПользовательИБ) Экспорт

	Роль = ОпределитьРольПользователя(ПользовательИБ);
	Возврат Роль = Перечисления.РольПользователя.Финансист
		ИЛИ Роль = Перечисления.РольПользователя.Администратор
		ИЛИ Роль = Перечисления.РольПользователя.Руководитель;

КонецФункции
