Процедура СоздатьУведомление(Получатель, ТипУведомления, Текст, Заказ = Неопределено, Отправка = Неопределено) Экспорт

	Если НЕ ЗначениеЗаполнено(Получатель) Тогда
		Возврат;
	КонецЕсли;

	ТипСтрокой = Лев(СокрЛП(Строка(ТипУведомления)), 50);
	ТекстУведомления = Лев(СокрЛП(Строка(Текст)), 500);
	Если ПустаяСтрока(ТекстУведомления) Тогда
		Возврат;
	КонецЕсли;

	Если ЕстьУведомлениеЗаСегодня(Получатель, ТипСтрокой, Заказ, Отправка, ТекстУведомления) Тогда
		Возврат;
	КонецЕсли;

	НаборЗаписей = РегистрыСведений.Уведомления.СоздатьНаборЗаписей();
	Запись = НаборЗаписей.Добавить();
	Запись.Период = ТекущаяДата();
	Запись.Получатель = Получатель;
	Запись.Тип = ТипСтрокой;
	Запись.Текст = ТекстУведомления;
	Запись.Прочитано = Ложь;
	Запись.ДатаПрочтения = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0);

	Если ЗначениеЗаполнено(Заказ) Тогда
		Запись.Заказ = Заказ;
	КонецЕсли;
	Если ЗначениеЗаполнено(Отправка) Тогда
		Запись.Отправка = Отправка;
	КонецЕсли;

	НаборЗаписей.Записать();

	ЗаписьЖурналаРегистрации(
		"ЛогикаУведомлений",
		УровеньЖурналаРегистрации.Информация,
		,
		,
		"Создано уведомление. Тип: " + ТипСтрокой + ", получатель: " + Строка(Получатель));

КонецПроцедуры

Процедура ВыполнитьРегламентОповещений() Экспорт
	СформироватьУведомленияПоПросроченнымОплатам();
	СформироватьУведомленияПоПросроченнымОтправкам();
КонецПроцедуры

Процедура СформироватьУведомленияПоПросроченнымОплатам()

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Финансы.Заказ КАК Заказ,
	|	МАКСИМУМ(Заказ.Менеджер) КАК Получатель,
	|	МИНИМУМ(Финансы.ДатаПлан) КАК ДатаПлана,
	|	СУММА(Финансы.СуммаРуб) КАК СуммаРуб
	|ИЗ
	|	РегистрСведений.ФинансыЗаказов КАК Финансы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Заказ КАК Заказ
	|		ПО Финансы.Заказ = Заказ.Ссылка
	|ГДЕ
	|	Финансы.ДатаПлан < &Сейчас
	|	И (Финансы.ДатаФакт = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|		ИЛИ Финансы.ДатаФакт > Финансы.ДатаПлан)
	|СГРУППИРОВАТЬ ПО
	|	Финансы.Заказ";
	Запрос.УстановитьПараметр("Сейчас", ТекущаяДата());

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если НЕ ЗначениеЗаполнено(Выборка.Получатель) Тогда
			Продолжить;
		КонецЕсли;

		Текст = "Просрочена оплата по заказу " + Строка(Выборка.Заказ)
			+ ". Плановая дата: " + Формат(Выборка.ДатаПлана, "ДФ=dd.MM.yyyy")
			+ ". Сумма, руб: " + Формат(Выборка.СуммаРуб, "ЧЦ=15; ЧДЦ=2");
		СоздатьУведомление(
			Выборка.Получатель,
			Перечисления.ТипУведомления.ПросрочкаОплаты,
			Текст,
			Выборка.Заказ);
	КонецЦикла;

КонецПроцедуры

Процедура СформироватьУведомленияПоПросроченнымОтправкам()

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Отправка.Ссылка КАК Отправка,
	|	МАКСИМУМ(Заказ.Менеджер) КАК Получатель,
	|	Отправка.ПланДатаПрибытия КАК ПланДатаПрибытия
	|ИЗ
	|	Документ.Отправка КАК Отправка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Отправка.Позиции КАК ПозицииОтправки
	|		ПО ПозицииОтправки.Ссылка = Отправка.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Заказ КАК Заказ
	|		ПО ПозицииОтправки.Заказ = Заказ.Ссылка
	|ГДЕ
	|	Отправка.ПланДатаПрибытия < &Сейчас
	|	И Отправка.ФактДатаПрибытия = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|СГРУППИРОВАТЬ ПО
	|	Отправка.Ссылка,
	|	Отправка.ПланДатаПрибытия";
	Запрос.УстановитьПараметр("Сейчас", ТекущаяДата());

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если НЕ ЗначениеЗаполнено(Выборка.Получатель) Тогда
			Продолжить;
		КонецЕсли;

		Текст = "Просрочено прибытие отправки " + Строка(Выборка.Отправка)
			+ ". Плановая дата прибытия: " + Формат(Выборка.ПланДатаПрибытия, "ДФ=dd.MM.yyyy");
		СоздатьУведомление(
			Выборка.Получатель,
			Перечисления.ТипУведомления.ЗадержкаДоставки,
			Текст,
			Неопределено,
			Выборка.Отправка);
	КонецЦикла;

КонецПроцедуры

Функция ЕстьУведомлениеЗаСегодня(Получатель, ТипУведомления, Заказ, Отправка, ТекстУведомления)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Уведомления.Период КАК Период
	|ИЗ
	|	РегистрСведений.Уведомления КАК Уведомления
	|ГДЕ
	|	Уведомления.Период МЕЖДУ &НачалоДня И &КонецДня
	|	И Уведомления.Получатель = &Получатель
	|	И Уведомления.Тип = &Тип
	|	И Уведомления.Текст = &Текст
	|	И (&ПустойЗаказ ИЛИ Уведомления.Заказ = &Заказ)
	|	И (&ПустаяОтправка ИЛИ Уведомления.Отправка = &Отправка)";
	Запрос.УстановитьПараметр("НачалоДня", НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("КонецДня", КонецДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Получатель", Получатель);
	Запрос.УстановитьПараметр("Тип", ТипУведомления);
	Запрос.УстановитьПараметр("Текст", ТекстУведомления);
	Запрос.УстановитьПараметр("ПустойЗаказ", НЕ ЗначениеЗаполнено(Заказ));
	Запрос.УстановитьПараметр("ПустаяОтправка", НЕ ЗначениеЗаполнено(Отправка));
	Запрос.УстановитьПараметр("Заказ", ?(ЗначениеЗаполнено(Заказ), Заказ, Документы.Заказ.ПустаяСсылка()));
	Запрос.УстановитьПараметр("Отправка", ?(ЗначениеЗаполнено(Отправка), Отправка, Документы.Отправка.ПустаяСсылка()));

	Возврат НЕ Запрос.Выполнить().Пустой();

КонецФункции
