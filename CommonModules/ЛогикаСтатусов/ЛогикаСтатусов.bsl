Функция ПроверитьПереходСтатуса(Категория, СтарыйСтатус, НовыйСтатус, РольПользователя = Неопределено) Экспорт

	Если НЕ ЗначениеЗаполнено(НовыйСтатус) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(СтарыйСтатус) Тогда
		// Первичное присвоение статуса допускается.
		Возврат Истина;
	КонецЕсли;

	Если СтарыйСтатус = НовыйСтатус Тогда
		Возврат Истина;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Переходы.РольПользователя КАК РольПользователя
	|ИЗ
	|	РегистрСведений.ПереходыСтатусов КАК Переходы
	|ГДЕ
	|	Переходы.Категория = &Категория
	|	И Переходы.СтатусИсточник = &СтарыйСтатус
	|	И Переходы.СтатусНазначение = &НовыйСтатус
	|	И Переходы.Разрешен";

	Запрос.УстановитьПараметр("Категория", Категория);
	Запрос.УстановитьПараметр("СтарыйСтатус", СтарыйСтатус);
	Запрос.УстановитьПараметр("НовыйСтатус", НовыйСтатус);

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если НЕ ЗначениеЗаполнено(РольПользователя) Тогда
			Возврат Истина;
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(Выборка.РольПользователя)
			ИЛИ Выборка.РольПользователя = РольПользователя Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;

	Возврат Ложь;

КонецФункции

Процедура ЗаписатьИсториюСтатуса(Заказ, Отправка, Категория, СтарыйСтатус, НовыйСтатус, Автор = Неопределено, Комментарий = "") Экспорт

	Если НЕ ЗначениеЗаполнено(Заказ) И НЕ ЗначениеЗаполнено(Отправка) Тогда
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Автор) Тогда
		Автор = ПолучитьТекущегоСотрудника();
	КонецЕсли;

	НаборЗаписей = РегистрыСведений.ИсторияСтатусов.СоздатьНаборЗаписей();
	Запись = НаборЗаписей.Добавить();
	Запись.Период = ТекущаяДата();

	Если ЗначениеЗаполнено(Заказ) Тогда
		Запись.Заказ = Заказ;
	КонецЕсли;

	Если ЗначениеЗаполнено(Отправка) Тогда
		Запись.Отправка = Отправка;
	КонецЕсли;

	Запись.Категория = Категория;

	Запись.СтарыйСтатус = СтарыйСтатус;
	Запись.НовыйСтатус = НовыйСтатус;
	Запись.Статус = НовыйСтатус;

	Если ЗначениеЗаполнено(Автор) Тогда
		Запись.Автор = Автор;
	КонецЕсли;
	Запись.Комментарий = Комментарий;

	НаборЗаписей.Записать();

КонецПроцедуры

Функция ПолучитьТекущегоСотрудника() Экспорт

	Попытка
		ТекущийПользователь = ПользователиИнформационнойБазы.ТекущийПользователь();
		Если ТекущийПользователь = Неопределено Тогда
			Возврат Справочники.Сотрудники.ПустаяСсылка();
		КонецЕсли;

		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Сотрудники.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Логин = &Логин";
		Запрос.УстановитьПараметр("Логин", ТекущийПользователь.Имя);

		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
		ПротоколироватьИсключение("Не удалось определить текущего сотрудника", ОписаниеОшибки());
	КонецПопытки;

	Возврат Справочники.Сотрудники.ПустаяСсылка();

КонецФункции

Процедура ПротоколироватьИсключение(Контекст, ТекстОшибки)
	ЗаписьЖурналаРегистрации(
		"ЛогикаСтатусов",
		УровеньЖурналаРегистрации.Ошибка,
		,
		,
		Контекст + ": " + ТекстОшибки);
КонецПроцедуры
