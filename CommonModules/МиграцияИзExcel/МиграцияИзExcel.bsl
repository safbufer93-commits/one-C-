Процедура ЗагрузитьСправочникиИзExcel(ПутьКФайлу) Экспорт
	ПроверитьПутьФайлаExcel(ПутьКФайлу);
	ТабДок = ПрочитатьФайлExcel(ПутьКФайлу);

	// На текущем этапе фиксируем успешное чтение файла и точку запуска миграции.
	ЗаписьЖурналаРегистрации(
		"МиграцияИзExcel",
		УровеньЖурналаРегистрации.Информация,
		,
		,
		"Запущена загрузка справочников из файла: " + ПутьКФайлу);
	Сообщить("Файл справочников успешно прочитан. Реализация построчной загрузки будет выполняться в следующем спринте.");
КонецПроцедуры

Процедура ЗагрузитьЗаказыИзExcel(ПутьКФайлу) Экспорт
	ПроверитьПутьФайлаExcel(ПутьКФайлу);
	ТабДок = ПрочитатьФайлExcel(ПутьКФайлу);

	ЗаписьЖурналаРегистрации(
		"МиграцияИзExcel",
		УровеньЖурналаРегистрации.Информация,
		,
		,
		"Запущена загрузка заказов из файла: " + ПутьКФайлу);
	Сообщить("Файл заказов успешно прочитан. Реализация импорта строк заказа будет выполняться в следующем спринте.");
КонецПроцедуры

Функция НормализоватьЗначениеНСИ(ИмяСправочника, ЗначениеИсточник) Экспорт

	Если НЕ ЗначениеЗаполнено(ЗначениеИсточник) Тогда
		Возврат "";
	КонецЕсли;

	ЗначениеСтрокой = СокрЛП(Строка(ЗначениеИсточник));
	Если ПустаяСтрока(ЗначениеСтрокой) Тогда
		Возврат "";
	КонецЕсли;

	Ключ = НРег(ЗначениеСтрокой);
	Карта = ПолучитьКартуНормализации(ИмяСправочника);
	Если Карта.СодержитКлюч(Ключ) Тогда
		Возврат Карта.Получить(Ключ);
	КонецЕсли;

	Возврат ЗначениеСтрокой;
КонецФункции

Функция ПрочитатьФайлExcel(ПутьКФайлу)

	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ПутьКФайлу);
		Возврат ТабДок;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(
			"МиграцияИзExcel",
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			"Ошибка чтения Excel: " + ТекстОшибки + ". Файл: " + ПутьКФайлу);
		ВызватьИсключение "Не удалось прочитать файл Excel: " + ТекстОшибки;
	КонецПопытки;

КонецФункции

Процедура ПроверитьПутьФайлаExcel(ПутьКФайлу)

	Если ПустаяСтрока(СокрЛП(ПутьКФайлу)) Тогда
		ВызватьИсключение "Не задан путь к файлу Excel.";
	КонецЕсли;

	Если НЕ ФайлСуществует(ПутьКФайлу) Тогда
		ВызватьИсключение "Файл Excel не найден: " + ПутьКФайлу;
	КонецЕсли;

КонецПроцедуры

Функция ПолучитьКартуНормализации(ИмяСправочника)

	Карта = Новый Соответствие;
	Имя = НРег(СокрЛП(Строка(ИмяСправочника)));

	Если Имя = "статусы" Тогда
		Карта.Вставить("в работе", "НаСогласовании");
		Карта.Вставить("в работе у поставщика", "ЗакупкаПодтверждена");
		Карта.Вставить("готово к отправке", "ВЛогистике");
		Карта.Вставить("доставлено", "ФинальнаяСправкаСформирована");
		Карта.Вставить("завершен", "Закрыт");
	ИначеЕсли Имя = "формаоплаты" Тогда
		Карта.Вставить("б/н", "Безнал");
		Карта.Вставить("безнал", "Безнал");
		Карта.Вставить("нал", "Наличные");
	ИначеЕсли Имя = "способдоставки" Тогда
		Карта.Вставить("дл", "Деловые линии");
		Карта.Вставить("сдэк", "СДЭК");
		Карта.Вставить("самовывоз", "Самовывоз");
		Карта.Вставить("авиа", "Авиа");
	КонецЕсли;

	Возврат Карта;

КонецФункции
