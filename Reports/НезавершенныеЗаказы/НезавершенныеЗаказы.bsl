Процедура Сформировать() Экспорт
	Данные = ПолучитьДанные();
	Сообщить("Отчет по незавершенным заказам сформирован. Количество строк: " + Формат(Данные.Количество(), "ЧГ=0"));
КонецПроцедуры

Функция ПолучитьДанные(ПериодНачало = Неопределено, ПериодКонец = Неопределено) Экспорт

	Если ПериодНачало = Неопределено Тогда
		ПериодНачало = НачалоГода(ТекущаяДата());
	КонецЕсли;
	Если ПериодКонец = Неопределено Тогда
		ПериодКонец = КонецДня(ТекущаяДата());
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Заказ.Ссылка КАК Заказ,
	|	Заказ.Дата КАК Дата,
	|	Заказ.Номер КАК Номер,
	|	Заказ.Заказчик КАК Заказчик,
	|	Заказ.Менеджер КАК Менеджер,
	|	Заказ.СтатусЗаказа КАК СтатусЗаказа,
	|	Заказ.СтатусОплатыПоСчету КАК СтатусОплаты,
	|	Заказ.СуммаЗаказаРуб КАК СуммаЗаказаРуб
	|ИЗ
	|	Документ.Заказ КАК Заказ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Статусы КАК Статусы
	|		ПО Заказ.СтатусЗаказа = Статусы.Ссылка
	|ГДЕ
	|	Заказ.Дата МЕЖДУ &ПериодНачало И &ПериодКонец
	|	И (Заказ.СтатусЗаказа = &ПустойСтатус
	|		ИЛИ ЕСТЬNULL(Статусы.Финальный, ЛОЖЬ) = ЛОЖЬ)
	|УПОРЯДОЧИТЬ ПО
	|	Заказ.Дата УБЫВ";
	Запрос.УстановитьПараметр("ПериодНачало", ПериодНачало);
	Запрос.УстановитьПараметр("ПериодКонец", ПериодКонец);
	Запрос.УстановитьПараметр("ПустойСтатус", Справочники.Статусы.ПустаяСсылка());

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции
