Процедура Сформировать() Экспорт
	Данные = ПолучитьДанные();
	Сообщить("Отчет ДДС сформирован. Количество строк: " + Формат(Данные.Количество(), "ЧГ=0"));
КонецПроцедуры

Функция ПолучитьДанные(ПериодНачало = Неопределено, ПериодКонец = Неопределено) Экспорт

	Если ПериодНачало = Неопределено Тогда
		ПериодНачало = НачалоМесяца(ТекущаяДата());
	КонецЕсли;
	Если ПериодКонец = Неопределено Тогда
		ПериодКонец = КонецДня(ТекущаяДата());
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Финансы.Период КАК Период,
	|	Финансы.Заказ КАК Заказ,
	|	Заказ.Заказчик КАК Заказчик,
	|	Финансы.ВидОплаты КАК ВидОплаты,
	|	Финансы.СтатусОплаты КАК СтатусОплаты,
	|	Финансы.СуммаРуб КАК СуммаРуб,
	|	Финансы.Валюта КАК Валюта,
	|	Финансы.Сумма КАК СуммаВалюты
	|ИЗ
	|	РегистрСведений.ФинансыЗаказов КАК Финансы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Заказ КАК Заказ
	|		ПО Финансы.Заказ = Заказ.Ссылка
	|ГДЕ
	|	Финансы.Период МЕЖДУ &ПериодНачало И &ПериодКонец
	|УПОРЯДОЧИТЬ ПО
	|	Финансы.Период,
	|	Финансы.Заказ";
	Запрос.УстановитьПараметр("ПериодНачало", ПериодНачало);
	Запрос.УстановитьПараметр("ПериодКонец", ПериодКонец);

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции
