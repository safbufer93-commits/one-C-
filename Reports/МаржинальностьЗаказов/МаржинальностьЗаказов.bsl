	ПолучитьДанные();
КонецПроцедуры

Функция ПолучитьДанные() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Заказ.Ссылка КАК Заказ,
	|	Заказ.Номер КАК Номер,
	|	Заказ.Дата КАК Дата,
	|	Заказ.Заказчик КАК Заказчик,
	|	Заказ.СуммаЗаказаРуб КАК СуммаЗаказаРуб,
	|	Заказ.СуммаМаржиРуб КАК СуммаМаржиРуб,
	|	Заказ.МаржаПроцент КАК МаржаПроцент
	|ИЗ
	|	Документ.Заказ КАК Заказ";
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции
