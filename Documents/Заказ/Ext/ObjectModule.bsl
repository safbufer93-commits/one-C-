Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	Если НЕ ЗначениеЗаполнено(Менеджер) Тогда
		Менеджер = ЛогикаЗаказов.ПолучитьТекущегоСотрудника();
	КонецЕсли;

	ТекстОшибки = "";
	ЛогикаЗаказов.ПроверитьЗаполнениеЗаказа(ЭтотОбъект, Отказ, ТекстОшибки);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	ЛогикаЗаказов.ПересчитатьЗаказ(ЭтотОбъект);

	Если НЕ ЗначениеЗаполнено(СтатусЗаказа) Тогда
		ЛогикаЗаказов.СохранитьЧерновик(ЭтотОбъект, "Автоматическое присвоение статуса");
	КонецЕсли;

КонецПроцедуры

Процедура СохранитьЧерновик(Комментарий = "") Экспорт
	ЛогикаЗаказов.СохранитьЧерновик(ЭтотОбъект, Комментарий);
КонецПроцедуры

Процедура ОтправитьНаСогласование(Комментарий = "") Экспорт
	ЛогикаЗаказов.ОтправитьНаСогласование(ЭтотОбъект, Комментарий);
КонецПроцедуры

Процедура Утвердить(Комментарий = "") Экспорт
	ЛогикаЗаказов.Утвердить(ЭтотОбъект, Комментарий);
КонецПроцедуры

Процедура ВернутьНаПравки(Комментарий) Экспорт
	Если ПустаяСтрока(СокрЛП(Комментарий)) Тогда
		ВызватьИсключение "Комментарий обязателен для возврата на правки.";
	КонецЕсли;
	ЛогикаЗаказов.ВернутьНаПравки(ЭтотОбъект, Комментарий);
КонецПроцедуры

Процедура Пересчитать() Экспорт
	ЛогикаЗаказов.ПересчитатьЗаказ(ЭтотОбъект);
КонецПроцедуры
