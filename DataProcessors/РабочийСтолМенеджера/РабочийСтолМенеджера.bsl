Процедура ПриСозданииНаСервере() Экспорт
	ОбновитьСписки();
КонецПроцедуры

Процедура ОбновитьСписки() Экспорт

	Если НЕ ЗначениеЗаполнено(ПериодНачало) Тогда
		ПериодНачало = НачалоМесяца(ТекущаяДата());
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ПериодКонец) Тогда
		ПериодКонец = КонецДня(ТекущаяДата());
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ТекущийМенеджер) Тогда
		ТекущийМенеджер = ЛогикаЗаказов.ПолучитьТекущегоСотрудника();
	КонецЕсли;

	Если ТолькоМоиЗаказы Тогда
		КоличествоСтрок = ПолучитьМоиЗаказы(ПериодНачало, ПериодКонец).Количество();
	Иначе
		КоличествоСтрок = ПолучитьСписокЗаказов(ПериодНачало, ПериодКонец).Количество();
	КонецЕсли;

	ЗаписьЖурналаРегистрации(
		"РабочийСтолМенеджера",
		УровеньЖурналаРегистрации.Информация,
		,
		,
		"Обновление рабочего стола. Заказов в выборке: " + Формат(КоличествоСтрок, "ЧГ=0"));

КонецПроцедуры

Функция ПолучитьМоиЗаказы(ПериодНачало = Неопределено, ПериодКонец = Неопределено) Экспорт

	Если ПериодНачало = Неопределено Тогда
		ПериодНачало = НачалоГода(ТекущаяДата());
	КонецЕсли;
	Если ПериодКонец = Неопределено Тогда
		ПериодКонец = КонецДня(ТекущаяДата());
	КонецЕсли;

	Менеджер = ЛогикаЗаказов.ПолучитьТекущегоСотрудника();
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Заказ.Ссылка КАК Заказ,
	|	Заказ.Дата КАК Дата,
	|	Заказ.Номер КАК Номер,
	|	Заказ.Заказчик КАК Заказчик,
	|	Заказ.СтатусЗаказа КАК СтатусЗаказа,
	|	Заказ.СуммаЗаказаРуб КАК СуммаЗаказаРуб
	|ИЗ
	|	Документ.Заказ КАК Заказ
	|ГДЕ
	|	Заказ.Дата МЕЖДУ &Начало И &Конец
	|	И (&ПоказыватьВсе ИЛИ Заказ.Менеджер = &Менеджер)
	|УПОРЯДОЧИТЬ ПО
	|	Заказ.Дата УБЫВ";
	Запрос.УстановитьПараметр("Начало", ПериодНачало);
	Запрос.УстановитьПараметр("Конец", ПериодКонец);
	Запрос.УстановитьПараметр("ПоказыватьВсе", НЕ ЗначениеЗаполнено(Менеджер));
	Запрос.УстановитьПараметр("Менеджер", ?(ЗначениеЗаполнено(Менеджер), Менеджер, Справочники.Сотрудники.ПустаяСсылка()));

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

Функция ПолучитьСписокЗаказов(ПериодНачало = Неопределено, ПериодКонец = Неопределено) Экспорт

	Если ПериодНачало = Неопределено Тогда
		ПериодНачало = НачалоГода(ТекущаяДата());
	КонецЕсли;
	Если ПериодКонец = Неопределено Тогда
		ПериодКонец = КонецДня(ТекущаяДата());
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Заказ.Ссылка КАК Заказ,
	|	Заказ.Дата КАК Дата,
	|	Заказ.Номер КАК Номер,
	|	Заказ.Заказчик КАК Заказчик,
	|	Заказ.Менеджер КАК Менеджер,
	|	Заказ.СтатусЗаказа КАК СтатусЗаказа,
	|	Заказ.СуммаЗаказаРуб КАК СуммаЗаказаРуб
	|ИЗ
	|	Документ.Заказ КАК Заказ
	|ГДЕ
	|	Заказ.Дата МЕЖДУ &Начало И &Конец
	|УПОРЯДОЧИТЬ ПО
	|	Заказ.Дата УБЫВ";
	Запрос.УстановитьПараметр("Начало", ПериодНачало);
	Запрос.УстановитьПараметр("Конец", ПериодКонец);

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции
